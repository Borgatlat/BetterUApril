# Copy to .env for local development (never commit .env).
# For EAS TestFlight builds, set the same keys in Expo dashboard → Project → Secrets
# or: npx eas-cli env:create --name EXPO_PUBLIC_OPENAI_API_KEY --value "..." --environment production

# Supabase (anon key is safe in the client; still prefer EAS secrets for rotation)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt

# AI — Future U uses Claude (Anthropic). Key must start with sk-ant-
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_FINETUNED_TRAINER_MODEL=

# Voice / LiveKit (URL only in client; API secret stays on Supabase Edge Function secrets)
EXPO_PUBLIC_LIVEKIT_URL=wss://your.livekit.cloud

# Maps (required for run maps on iOS TestFlight)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# AdMob (production app + banner unit IDs from AdMob console)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx
EXPO_PUBLIC_ADMOB_IOS_BANNER_AD_UNIT_ID=ca-app-pub-xxxxxxxx/xxxxxxxx
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_AD_UNIT_ID=ca-app-pub-xxxxxxxx/xxxxxxxx

# Local-only: free Apple Personal Team builds (disables push / Sign in with Apple plugins)
# IOS_PERSONAL_DEV=1

# Server-only (NOT bundled in the app — Supabase Edge Functions / CI only)
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
